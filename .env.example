# AgentTrust MCP — environment configuration

# Path to SQLite DB file. Defaults to ./agenttrust.db
AGENTTRUST_DB=./agenttrust.db

# Default dev API key seeded on startup (free tier, 100 writes/day)
AGENTTRUST_DEV_KEY=agenttrust-dev-key-001

# Optional: admin key for verify_agent and resolve_dispute (defaults to dev key if unset)
AGENTTRUST_ADMIN_KEY=agenttrust-admin-key-001

# Public base URL used in 429 upgrade messages
AGENTTRUST_UPGRADE_URL=https://mcpize.com/agenttrust-mcp

# Server port (Railway injects PORT)
PORT=8000
